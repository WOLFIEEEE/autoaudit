        "html_snippet": "<button class=\"button button-icon button-nobg button-noborder\"><span><svg focusable=\"false\" aria-label=\"Submit Search\" class=\"icon-search \"><use xlink:href=\"/WAI/assets/images/icons.svg#icon-search\"><",
        "text_content": ""
      },
      "details": {
        "tag": "button",
        "role": "",
        "tab_index": 9
      },
      "fix_suggestion": "Add visible text, aria-label, or a <label for> associating the control with a descriptive label."
